{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "allowJs": true
  },
  "include": [
    "apps/**/src/**/*",
    "apps/**/tests/**/*",
    "apps/**/*.config.ts",
    "packages/**/src/**/*",
    "eslint.config.js"
  ]
}
