# PostgreSQL local (no usar credenciales reales)
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=cambiar-en-local
POSTGRES_DB=factuflow
POSTGRES_PORT=5432

# Roles separados: migraciones (owner) y aplicación (app)
FACTUFLOW_OWNER_USER=factuflow_owner
FACTUFLOW_OWNER_PASSWORD=cambiar-en-local
FACTUFLOW_APP_USER=factuflow_app
FACTUFLOW_APP_PASSWORD=cambiar-en-local

# Conexiones desde procesos ejecutados en el host
DATABASE_URL_OWNER=postgresql://factuflow_owner:cambiar-en-local@localhost:5432/factuflow
DATABASE_URL_APP=postgresql://factuflow_app:cambiar-en-local@localhost:5432/factuflow

NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000
WEB_PORT=5173
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:3000
VITE_SESSION_COOKIE_NAME=factuflow_session

# Autenticación y sesiones (Fase 2)
SESSION_COOKIE_NAME=factuflow_session
SESSION_IDLE_MINUTES=480
SESSION_ABSOLUTE_MINUTES=1440
SESSION_ACTIVITY_UPDATE_MINUTES=5
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_LOCK_MINUTES=15
LOGIN_ATTEMPT_RETENTION_DAYS=90
PASSWORD_HASH_MEMORY_KIB=65536
PASSWORD_HASH_TIME_COST=3
PASSWORD_HASH_PARALLELISM=1
